{
  "$schema": "http://json-schema.org/schema",
  "$comment": "Session configuration (ClientSession) for <https://github.com/redmer/link-beoordeelaar>.",
  "type": "object",
  "required": ["questions", "links"],
  "properties": {
    "lang": {
      "$comment": "The interface language",
      "type": "string",
      "enum": ["nl", "en"]
    },
    "questions": {
      "$comment": "The ordered list of questions to ask for each subject.",
      "type": "array",
      "items": { "$ref": "#/definitions/Question" }
    },
    "links": {
      "type": "object",
      "required": ["next"],
      "properties": {
        "next": {
          "$comment": "URL to /datasets/{id}/next-subject on the backend, optionally with ?filter=...",
          "type": "string",
          "format": "uri"
        },
        "help": {
          "$comment": "Link shown in the page footer; defaults to the bundled help page.",
          "type": "string",
          "format": "uri"
        }
      }
    }
  },
  "definitions": {
    "Question": {
      "type": "object",
      "required": ["id", "mode", "label", "options"],
      "properties": {
        "id": {
          "$comment": "Identifier; matches a key in the saved `answers` object.",
          "type": "string"
        },
        "mode": {
          "$comment": "Single- or multi-choice.",
          "type": "string",
          "enum": ["one", "multiple"]
        },
        "label": { "type": "string" },
        "options": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/AnswerOption" }
        }
      }
    },
    "AnswerOption": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": {
          "$comment": "Machine-readable value, stored in answers.",
          "type": "string"
        },
        "label": {
          "$comment": "Human-readable label shown in the interface.",
          "type": "string"
        },
        "description": {
          "$comment": "Optional sub-label.",
          "type": "string"
        },
        "final": {
          "$comment": "When true, this answer alone marks the subject as done.",
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
