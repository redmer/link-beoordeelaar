{
  "compilerOptions": {
    "lib": [
      "ES5",
      "DOM",
      "ES2015",
      "ES2016",
      "ES2017",
      "ES2018",
      "ES2019",
      "ES2020",
      "ES2021"
    ],
    "importHelpers": true,
    "target": "ES2021",
    "checkJs": true,
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["jest"],
    "esModuleInterop": true,
    "module": "nodenext"
  },
  "exclude": ["node_modules", "build", "rollup.config.js"]
}
