{
  "compilerOptions": {
    "lib": ["DOM", "ES2025"],
    // "importHelpers": true,
    "target": "es2025",
    "checkJs": true,
    "strict": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["jest"],
    "esModuleInterop": true,
    "module": "esnext",
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "exclude": ["node_modules", "build", "rollup.config.js", "jest.config.js"]
}
